{
  "module": "zeropay-module",
  "enabled": true,
  "route": "/app/zeropay-module",
  "offline_mode": "read_cached_summary_only",
  "screens": [
    "module_dashboard",
    "module_chat",
    "module_tables",
    "module_settings"
  ],
  "capabilities": [
    "push_notifications",
    "voice_input",
    "camera_uploads",
    "file_uploads",
    "quick_actions"
  ],
  "agent": {
    "chat_enabled": true,
    "voice_enabled": true,
    "control_enabled": true,
    "confirmation_required_for_writes": true
  }
}
