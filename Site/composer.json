{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/vue-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "alizharb/filament-activity-log": "^1.3",
        "alizharb/filament-themes-manager": "^1.0",
        "andreia/filament-ui-switcher": "^1.1",
        "attargah/admin-bar": "^1.0",
        "awcodes/filament-badgeable-column": "^3.1",
        "awcodes/filament-curator": "^5.0",
        "bezhansalleh/filament-panel-switch": "*",
        "bezhansalleh/filament-shield": "^4.2",
        "biostate/filament-menu-builder": "^4.0",
        "devonab/filament-easy-footer": "^2.2",
        "eightynine/filament-advanced-widgets": "^4.0",
        "filafly/filament-hugeicons-icons": "^1.1",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0",
        "filament/spatie-laravel-settings-plugin": "^4.0",
        "inertiajs/inertia-laravel": "^2.0",
        "jeffersongoncalves/filament-ace-editor-field": "^1.0",
        "jeffersongoncalves/filament-topbar": "*",
        "jeffgreco13/filament-breezy": "^3.1",
        "lara-zeus/dynamic-dashboard": "^4.0",
        "laravel/fortify": "^1.30",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.10",
        "laravel/tinker": "^2.10.1",
        "laravel/wayfinder": "^0.1.9",
        "leandrocfe/filament-apex-charts": "^4.0",
        "notebrainslab/filament-menu-manager": "^1.0",
        "novadaemon/filament-combobox": "*",
        "openplain/filament-shadcn-theme": "^1.1",
        "osamaatef/filament-drilldown-sidebar": "*",
        "osamanagi/filament-abyss-theme": "^1.0",
        "pxlrbt/filament-excel": "^3.6",
        "pxlrbt/filament-spotlight": "^2.1",
        "rawilk/filament-password-input": "^3.1",
        "redberry/page-builder-plugin": "^2.0",
        "relaticle/flowforge": "^3.0",
        "savannabits/filament-modules": "^5.1",
        "sentry/sentry-laravel": "^4.25",
        "shreejan/dash-arrange": "^1.0",
        "solution-forest/tab-layout-plugin": "^4.0",
        "spatie/laravel-permission": "^7.0",
        "spykapps/filament-uppy-upload": "^1.0",
        "stripe/stripe-php": "^20.0",
        "symfony/sendgrid-mailer": "^8.0",
        "tapp/filament-progress-bar-column": "^1.0",
        "tomatophp/filament-cms": "^4.0",
        "tomatophp/filament-settings-hub": "^4.0",
        "twilio/sdk": "^8.11"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php -d memory_limit=512M vendor/bin/pest"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
